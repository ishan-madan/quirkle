{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@engine": ["../packages/engine/src/index.ts"],
      "@engine/*": ["../packages/engine/src/*"]
    }
  },
  "include": ["src"]
}
